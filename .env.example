# Copy to .env and adjust: `cp .env.example .env`
#
# --- Host UID/GID (files in bind-mounted ./ stay owned by your user) ---
# DOCKER_UID=1000
# DOCKER_GID=1000
#
# LD_PRELOAD: leave unset — the image entrypoint sets it on aarch64 only (see
# scripts/container-entrypoint.sh). Set here only to override or fix sklearn paths.
# LD_PRELOAD=...
#
# --- ISP (optional overrides; defaults work for single GPU) ---
# ISP_NUM_GPUS=1
